---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Search from "astro-pagefind/components/Search";
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const query = Astro.url.searchParams.get("q") || "";
---

<!doctype html>
<html lang="en">
	<head>
		<script is:inline>
			if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
				document.documentElement.classList.add('dark')
			} else {
				document.documentElement.classList.remove('dark')
			}
		</script>
		<BaseHead title={`Search ${query ? `- ${query}` : ''} | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			body {
				padding-bottom: 6rem;
			}

			main {
				max-width: 800px;
				margin: 0 auto;
				padding: 2rem 1rem;
			}

			.search-header {
				margin-bottom: 2rem;
			}

			.search-title {
				font-size: 2.5rem;
				font-weight: bold;
				margin-bottom: 1rem;
				color: #000;
			}

			.dark .search-title {
				color: #fff;
			}

			.search-subtitle {
				color: #6b7280;
				font-size: 1rem;
			}

			.dark .search-subtitle {
				color: #9ca3af;
			}

			@media (max-width: 768px) {
				.search-title {
					font-size: 2rem;
				}

				main {
					padding: 1rem;
				}
			}

			/* Custom fade-in-down animation */
			@keyframes fadeInDown {
				from {
					opacity: 0;
					transform: translateY(-30px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			.animate-fadeInDown {
				animation: fadeInDown 0.8s ease-out forwards;
				opacity: 0;
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="animate-fadeInDown">
			<div class="search-header animate-fadeInDown" style="animation-delay: 0.1s;">
				<h1 class="search-title">Search</h1>
				<p class="search-subtitle">Find articles and content across the blog</p>
			</div>

			<div class="animate-fadeInDown" style="animation-delay: 0.2s;">
				<Search
					id="search"
					className="pagefind-search"
					query={query}
					uiOptions={{
						showImages: false,
						excerptLength: 30
					}}
				/>
			</div>
		</main>
		<Footer />

		<style is:global>
			.pagefind-search {
				padding: 1rem 0;
			}

			.pagefind-ui__search-input {
				background-color: rgba(230, 228, 224, 0.9) !important;
				border: 1px solid #9ca3af !important;
				border-radius: 20px !important;
				font-size: 1rem !important;
				padding: 0.75rem 1rem !important;
				color: #000 !important;
				width: 100% !important;
			}

			.dark .pagefind-ui__search-input {
				background-color: rgba(30, 30, 30, 0.9) !important;
				border-color: #4b5563 !important;
				color: #fff !important;
			}

			.pagefind-ui__search-input:focus {
				outline: none !important;
				border-color: #9ca3af !important;
				background-color: rgba(200, 198, 194, 0.8) !important;
			}

			.dark .pagefind-ui__search-input:focus {
				border-color: #4b5563 !important;
				background-color: rgba(60, 60, 60, 0.8) !important;
			}

			.pagefind-ui__search-input::placeholder {
				color: rgba(0, 0, 0, 0.6) !important;
			}

			.dark .pagefind-ui__search-input::placeholder {
				color: rgba(255, 255, 255, 0.6) !important;
			}

			.pagefind-ui__results {
				margin-top: 1.5rem !important;
			}

			.pagefind-ui__result {
				padding: 1.25rem !important;
				border-radius: 12px !important;
				margin-bottom: 1rem !important;
				border: 1px solid #d1d5db !important;
				background-color: transparent !important;
				transition: all 0.2s ease !important;
			}

			.dark .pagefind-ui__result {
				border-color: #4b5563 !important;
			}

			.pagefind-ui__result:hover {
				background-color: rgba(0, 0, 0, 0.02) !important;
				border-color: #9ca3af !important;
			}

			.dark .pagefind-ui__result:hover {
				background-color: rgba(255, 255, 255, 0.05) !important;
				border-color: #6b7280 !important;
			}

			.pagefind-ui__result-link {
				color: #000 !important;
				text-decoration: none !important;
			}

			.dark .pagefind-ui__result-link {
				color: #fff !important;
			}

			.pagefind-ui__result-title {
				font-weight: 600 !important;
				margin-bottom: 0.5rem !important;
				color: #111827 !important;
				font-size: 1.125rem !important;
			}

			.dark .pagefind-ui__result-title {
				color: #f9fafb !important;
			}

			.pagefind-ui__result-excerpt {
				font-size: 0.875rem !important;
				color: #6b7280 !important;
				line-height: 1.6 !important;
			}

			.dark .pagefind-ui__result-excerpt {
				color: #9ca3af !important;
			}

			.pagefind-ui__message {
				padding: 2rem 0 !important;
				text-align: center !important;
				color: #6b7280 !important;
			}

			.dark .pagefind-ui__message {
				color: #9ca3af !important;
			}

			.pagefind-ui__button {
				background-color: rgba(230, 228, 224, 0.9) !important;
				border: 1px solid #9ca3af !important;
				border-radius: 8px !important;
				padding: 0.5rem 1rem !important;
				color: #000 !important;
				transition: all 0.2s ease !important;
			}

			.dark .pagefind-ui__button {
				background-color: rgba(30, 30, 30, 0.9) !important;
				border-color: #4b5563 !important;
				color: #fff !important;
			}

			.pagefind-ui__button:hover {
				background-color: rgba(200, 198, 194, 0.8) !important;
			}

			.dark .pagefind-ui__button:hover {
				background-color: rgba(60, 60, 60, 0.8) !important;
			}

			/* Search result highlights */
			mark {
				background-color: rgba(220, 38, 38, 0.2) !important;
				color: inherit !important;
				padding: 0 2px !important;
				border-radius: 2px !important;
			}

			.dark mark {
				background-color: rgba(220, 38, 38, 0.3) !important;
			}
		</style>
	</body>
</html>
