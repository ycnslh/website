---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import SkipLink from '../../components/SkipLink.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Badge from '../../components/ui/Badge.astro';
import Card from '../../components/ui/Card.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

export async function getStaticPaths({ paginate }) {
	const allPosts = await getCollection('blog');
	const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

	return paginate(sortedPosts, { pageSize: 10 });
}

const { page } = Astro.props;
const posts = page.data;

// Get tags and reading time from frontmatter using import.meta.glob
const postModules = import.meta.glob('../../content/blog/*.{md,mdx}', { eager: true });
const postsWithMetadata = posts.map((post: any) => {
	const postPath = `../../content/blog/${post.id}.md`;
	const postPathMdx = `../../content/blog/${post.id}.mdx`;
	const module = postModules[postPath] || postModules[postPathMdx];

	// Calculate reading time from body
	const body = (module as any)?.rawContent?.() || '';
	const wordsPerMinute = 200;
	const words = body.trim().split(/\s+/).filter(Boolean).length;
	const readingTime = Math.max(1, Math.ceil(words / wordsPerMinute));

	return {
		...post,
		tags: (module as any)?.frontmatter?.tags || [],
		readingTime: `${readingTime} min read`,
	};
});
---

<!doctype html>
<html lang="en">
	<head>
		<script is:inline>
			if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
				document.documentElement.classList.add('dark')
			} else {
				document.documentElement.classList.remove('dark')
			}
		</script>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 800px;
				margin: 0 auto;
				padding: 2rem 1rem;
			}

			.blog-header {
				margin-bottom: 3rem;
			}

			.blog-title {
				font-size: 2.5rem;
				font-weight: bold;
				margin-bottom: 0.5rem;
				color: var(--color-text);
			}

			.blog-subtitle {
				color: var(--color-muted);
				font-size: 1rem;
			}

			.posts-list {
				display: flex;
				flex-direction: column;
				gap: 2rem;
			}

			.post-card-link {
				text-decoration: none;
				color: inherit;
				display: block;
				height: 100%;
			}

			.post-card-layout {
				display: flex;
				gap: 1.5rem;
				height: 100%;
			}

			.post-card-image {
				flex-shrink: 0;
				width: 240px;
				height: 160px;
				overflow: hidden;
				border-radius: 8px;
			}

			.post-card-image img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 300ms ease;
			}

			.post-card-link:hover .post-card-image img {
				transform: scale(1.05);
			}

			.post-card-content {
				flex: 1;
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				min-width: 0;
			}

			.post-card-main {
				flex: 1;
			}

			.post-card-title {
				font-size: 1.5rem;
				font-weight: 600;
				color: var(--color-text);
				margin-bottom: 0.5rem;
				transition: color 200ms ease;
				line-height: 1.3;
			}

			.post-card-link:hover .post-card-title {
				color: var(--color-accent);
			}

			.post-card-description {
				color: var(--color-muted);
				font-size: 0.9375rem;
				line-height: 1.6;
				margin-bottom: 1rem;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.post-card-meta {
				display: flex;
				align-items: center;
				gap: 1rem;
				font-size: 0.875rem;
				color: var(--color-muted);
				flex-wrap: wrap;
				margin-bottom: 0.75rem;
			}

			.post-card-date {
				display: flex;
				align-items: center;
				gap: 0.25rem;
			}

			.post-card-reading-time {
				display: flex;
				align-items: center;
				gap: 0.25rem;
			}

			.post-card-tags {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
				margin-top: auto;
			}

			@media (max-width: 768px) {
				.blog-title {
					font-size: 2rem;
				}

				main {
					padding: 1rem;
				}

				.posts-list {
					gap: 1.5rem;
				}

				.post-card-layout {
					flex-direction: column;
				}

				.post-card-image {
					width: 100%;
					height: 200px;
				}

				.post-card-title {
					font-size: 1.25rem;
				}

				.post-card-description {
					-webkit-line-clamp: 3;
				}
			}

			/* Pagination styles */
			.pagination {
				display: flex;
				justify-content: center;
				align-items: center;
				gap: 2rem;
				margin-top: 3rem;
				padding: 2rem 0;
			}

			.pagination-link {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				padding: 0.75rem 1.5rem;
				border: 1px solid var(--color-border);
				border-radius: 8px;
				text-decoration: none;
				color: var(--color-text);
				font-weight: 500;
				background: var(--color-surface);
				transition: background 200ms ease, transform 200ms ease, border-color 200ms ease;
			}

			.pagination-link:hover {
				background: var(--color-accent);
				border-color: var(--color-accent);
				color: white;
				transform: translateY(-2px);
			}

			.pagination-info {
				color: var(--color-muted);
				font-weight: 500;
			}

			@media (max-width: 768px) {
				.pagination {
					flex-direction: column;
					gap: 1rem;
				}
			}
		</style>
	</head>
	<body>
		<SkipLink />
		<Header />
		<Breadcrumbs items={[
			{ label: 'Home', href: '/' },
			{ label: 'Blog' }
		]} />
		<main id="main-content">
			<div class="blog-header">
				<h1 class="blog-title">Blog</h1>
				<p class="blog-subtitle">Page {page.currentPage} - Showing {((page.currentPage - 1) * page.size) + 1}-{Math.min(page.currentPage * page.size, page.total)} of {page.total} posts</p>
			</div>

			<div class="posts-list">
				{postsWithMetadata.map((post: any) => (
					<Card hover>
						<a href={`/blog/${post.id}/`} class="post-card-link">
							<div class="post-card-layout">
								{post.data.heroImage && (
									<div class="post-card-image">
										<Image
											src={post.data.heroImage}
											alt={post.data.title}
											width={300}
											height={200}
											class="post-image"
										/>
									</div>
								)}
								<div class="post-card-content">
									<div class="post-card-main">
										<h2 class="post-card-title">{post.data.title}</h2>
										<p class="post-card-description">{post.data.description}</p>
										<div class="post-card-meta">
											<span class="post-card-date">
												<svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24">
													<path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z"/>
												</svg>
												<FormattedDate date={post.data.pubDate} />
											</span>
											{post.readingTime && (
												<span class="post-card-reading-time">📖 {post.readingTime}</span>
											)}
										</div>
									</div>
									{post.tags && post.tags.length > 0 && (
										<div class="post-card-tags">
											{post.tags.map((tag: string) => (
												<Badge variant="default" href={`/tags/${tag}/`}>{tag}</Badge>
											))}
										</div>
									)}
								</div>
							</div>
						</a>
					</Card>
				))}
			</div>

			{(page.url.prev || page.url.next) && (
				<div class="pagination">
					{page.url.prev && (
						<a href={page.url.prev} class="pagination-link pagination-prev">
							<svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
								<path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
							</svg>
							Previous
						</a>
					)}

					<span class="pagination-info">
						Page {page.currentPage} of {page.lastPage}
					</span>

					{page.url.next && (
						<a href={page.url.next} class="pagination-link pagination-next">
							Next
							<svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
								<path d="M8.59 16.59L10 18l6-6-6-6-1.41 1.41L13.17 12z"/>
							</svg>
						</a>
					)}
				</div>
			)}
		</main>
		<Footer />

	</body>
</html>
