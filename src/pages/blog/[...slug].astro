---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import getReadingTime from 'reading-time';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const postModules = import.meta.glob('../../content/blog/*.{md,mdx}', { eager: true });

	return posts.map((post) => {
		// Trouver le module correspondant pour récupérer les tags du frontmatter
		const matchingModule = Object.values(postModules).find((module: any) =>
			module.frontmatter?.title === post.data.title
		) as any;

		return {
			params: { slug: post.id },
			props: {
				...post,
				tags: matchingModule?.frontmatter?.tags || []
			},
		};
	});
}
type Props = CollectionEntry<'blog'> & { tags: string[] };

const post = Astro.props;
const { Content, headings } = await render(post);
const readingTime = getReadingTime(post.body);
---

<BlogPost {...post.data} tags={post.tags} readingTime={readingTime.text} headings={headings}>
	<Content />
</BlogPost>
