---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Card from '../components/ui/Card.astro';
import SkipLink from '../components/SkipLink.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="About - Reho" description="About Reho - Systems Engineer building reliable infrastructure and sharing knowledge" />
		<style>
			main {
				max-width: 900px;
				margin: 0 auto;
				padding: 4rem 1rem;
			}

			.page-header {
				text-align: center;
				margin-bottom: 4rem;
			}

			.page-title {
				font-size: clamp(2.5rem, 5vw, 3.5rem);
				font-weight: 800;
				margin-bottom: 1rem;
				color: var(--color-text);
			}

			.page-subtitle {
				font-size: 1.25rem;
				color: var(--color-muted);
				max-width: 600px;
				margin: 0 auto;
				line-height: 1.6;
			}

			.content-section {
				margin-bottom: 3rem;
			}

			.section-title {
				font-size: 1.75rem;
				font-weight: 700;
				margin-bottom: 1.5rem;
				color: var(--color-text);
			}

			.bio {
				font-size: 1.125rem;
				line-height: 1.8;
				color: var(--color-text);
				margin-bottom: 2rem;
			}

			.bio p {
				margin-bottom: 1rem;
			}

			.skills-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
				gap: 1.5rem;
				margin-top: 2rem;
			}

			.skill-category {
				padding: 1.5rem;
			}

			.skill-category h3 {
				font-size: 1.125rem;
				font-weight: 600;
				margin-bottom: 1rem;
				color: var(--color-text);
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}

			.skill-category h3 svg {
				color: var(--color-accent);
			}

			.skill-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}

			.skill-list li {
				padding: 0.5rem 0;
				color: var(--color-muted);
				font-size: 0.9375rem;
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}

			.skill-list li::before {
				content: "▹";
				color: var(--color-accent);
				font-weight: bold;
			}

			.contact-section {
				text-align: center;
				margin-top: 4rem;
				padding: 3rem 2rem;
				background: var(--color-surface);
				border-radius: 16px;
			}

			.contact-title {
				font-size: 1.5rem;
				font-weight: 700;
				margin-bottom: 1rem;
				color: var(--color-text);
			}

			.contact-description {
				font-size: 1.125rem;
				color: var(--color-muted);
				margin-bottom: 2rem;
			}

			.social-links {
				display: flex;
				gap: 1.5rem;
				justify-content: center;
				flex-wrap: wrap;
			}

			.social-link {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				padding: 0.75rem 1.5rem;
				border-radius: 9999px;
				background: var(--color-bg);
				border: 1px solid var(--color-border);
				color: var(--color-text);
				text-decoration: none;
				font-weight: 500;
				transition: background 200ms ease, transform 200ms ease, border-color 200ms ease;
			}

			.social-link:hover {
				background: var(--color-accent);
				border-color: var(--color-accent);
				color: white;
				transform: translateY(-2px);
			}

			@media (max-width: 768px) {
				main {
					padding: 2rem 1rem;
				}

				.skills-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<SkipLink />
		<Header />
		<Breadcrumbs items={[
			{ label: 'Home', href: '/' },
			{ label: 'About' }
		]} />
		<main id="main-content">
			<div class="page-header">
				<h1 class="page-title">About Me</h1>
				<p class="page-subtitle">
					Systems Engineer passionate about building reliable infrastructure and automation
				</p>
			</div>

			<div class="content-section">
				<div class="bio">
					<p>
						Hi, I'm Reho, a Systems Engineer with a passion for building and maintaining reliable, scalable infrastructure.
						I specialize in automation, cloud architecture, and DevOps practices that help teams ship faster and more confidently.
					</p>
					<p>
						My journey in systems engineering has taken me through various challenges—from designing resilient Kubernetes clusters
						to implementing comprehensive CI/CD pipelines, and from optimizing cloud costs to ensuring security best practices.
						I believe in the power of Infrastructure as Code and the importance of treating operations with the same rigor as development.
					</p>
					<p>
						Through this blog, I share insights, tutorials, and lessons learned from working with modern infrastructure tools and practices.
						Whether you're starting your DevOps journey or looking to deepen your expertise, I hope you'll find something useful here.
					</p>
				</div>
			</div>

			<div class="content-section">
				<h2 class="section-title">Skills & Technologies</h2>
				<div class="skills-grid">
					<Card>
						<div class="skill-category">
							<h3>
								<svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
									<path d="M20 6h-2.18c.11-.31.18-.65.18-1a2.996 2.996 0 0 0-5.5-1.65l-.5.67-.5-.68C10.96 2.54 10.05 2 9 2 7.34 2 6 3.34 6 5c0 .35.07.69.18 1H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zm-5-2c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zM9 4c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm11 15H4v-2h16v2zm0-5H4V8h5.08L7 10.83 8.62 12 11 8.76l1-1.36 1 1.36L15.38 12 17 10.83 14.92 8H20v6z"/>
								</svg>
								Infrastructure
							</h3>
							<ul class="skill-list">
								<li>Kubernetes & Docker Orchestration</li>
								<li>Terraform & Infrastructure as Code</li>
								<li>Cloud Platforms (AWS, GCP, Azure)</li>
								<li>CI/CD Pipelines (GitHub Actions, GitLab CI)</li>
								<li>Service Mesh & Networking</li>
							</ul>
						</div>
					</Card>

					<Card>
						<div class="skill-category">
							<h3>
								<svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
									<path d="M9.4 16.6 4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0 4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z"/>
								</svg>
								Development
							</h3>
							<ul class="skill-list">
								<li>Python (Automation & Scripting)</li>
								<li>Go (Tools & Services)</li>
								<li>Bash & Shell Scripting</li>
								<li>REST APIs & Webhooks</li>
								<li>Git & Version Control</li>
							</ul>
						</div>
					</Card>

					<Card>
						<div class="skill-category">
							<h3>
								<svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
									<path d="M12 1 3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/>
								</svg>
								Practices
							</h3>
							<ul class="skill-list">
								<li>Monitoring & Observability (Prometheus, Grafana)</li>
								<li>Security Best Practices & Hardening</li>
								<li>Site Reliability Engineering (SRE)</li>
								<li>Incident Response & On-Call</li>
								<li>Technical Documentation</li>
							</ul>
						</div>
					</Card>
				</div>
			</div>

			<div class="contact-section">
				<h2 class="contact-title">Let's Connect</h2>
				<p class="contact-description">
					Feel free to reach out on social media or check out my code on GitHub
				</p>
				<div class="social-links">
					<a href="https://github.com/soulkill3r" target="_blank" rel="noopener noreferrer" class="social-link">
						<svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
							<path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
						</svg>
						GitHub
					</a>
					<a href="https://x.com/__reho" target="_blank" rel="noopener noreferrer" class="social-link">
						<svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
							<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
						</svg>
						X (Twitter)
					</a>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
