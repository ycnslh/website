---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SkipLink from '../../components/SkipLink.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { SITE_TITLE } from '../../consts';

const postModules = import.meta.glob('../../content/blog/*.{md,mdx}', { eager: true });
const allPosts = Object.values(postModules);

// Count posts per tag
const tagCounts: Record<string, number> = {};
allPosts.forEach((post: any) => {
	const postTags = post.frontmatter?.tags || [];
	postTags.forEach((tag: string) => {
		tagCounts[tag] = (tagCounts[tag] || 0) + 1;
	});
});

// Sort tags by count (descending) then alphabetically
const sortedTags = Object.entries(tagCounts).sort((a, b) => {
	if (b[1] !== a[1]) return (b[1] as number) - (a[1] as number); // By count
	return a[0].localeCompare(b[0]); // Then alphabetically
});
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Tags - ${SITE_TITLE}`} description="Browse all blog post tags" />
		<style>
			main {
				max-width: 1000px;
				margin: 0 auto;
				padding: 4rem 1rem;
			}

			.page-header {
				text-align: center;
				margin-bottom: 4rem;
			}

			.page-title {
				font-size: clamp(2.5rem, 5vw, 3.5rem);
				font-weight: 800;
				margin-bottom: 1rem;
				color: var(--color-text);
			}

			.page-subtitle {
				font-size: 1.125rem;
				color: var(--color-muted);
			}

			.tags-container {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem;
				justify-content: center;
			}

			.tag-badge {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				padding: 0.5rem 1rem;
				background: var(--color-surface);
				border: 1px solid var(--color-border);
				border-radius: 9999px;
				text-decoration: none;
				transition: all 200ms ease;
			}

			.tag-badge:hover {
				background: var(--color-accent);
				border-color: var(--color-accent);
				transform: scale(1.05);
			}

			.tag-name {
				font-size: 0.9375rem;
				font-weight: 500;
				color: var(--color-text);
				transition: color 200ms ease;
			}

			.tag-badge:hover .tag-name {
				color: white;
			}

			.tag-count {
				font-size: 0.75rem;
				padding: 0.125rem 0.5rem;
				background: var(--color-bg);
				border-radius: 9999px;
				color: var(--color-muted);
				font-weight: 600;
				transition: all 200ms ease;
			}

			.tag-badge:hover .tag-count {
				background: rgba(255, 255, 255, 0.2);
				color: white;
			}

			.total-tags {
				text-align: center;
				margin-bottom: 3rem;
				font-size: 1rem;
				color: var(--color-muted);
			}

			@media (max-width: 768px) {
				main {
					padding: 2rem 1rem;
				}

				.tags-container {
					justify-content: flex-start;
				}
			}
		</style>
	</head>
	<body>
		<SkipLink />
		<Header />
		<Breadcrumbs items={[
			{ label: 'Home', href: '/' },
			{ label: 'Tags' }
		]} />
		<main id="main-content">
			<div class="page-header">
				<h1 class="page-title">Tags</h1>
				<p class="page-subtitle">Explore posts by topic</p>
			</div>

			<p class="total-tags">
				{sortedTags.length} {sortedTags.length === 1 ? 'tag' : 'tags'} total
			</p>

			<div class="tags-container">
				{sortedTags.map(([tag, count]) => (
					<a href={`/tags/${tag}/`} class="tag-badge">
						<span class="tag-name">{tag}</span>
						<span class="tag-count">{count}</span>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>
