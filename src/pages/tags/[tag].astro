---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SkipLink from '../../components/SkipLink.astro';
import { SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
	const postModules = import.meta.glob('../../content/blog/*.{md,mdx}', { eager: true });
	const allPosts = Object.entries(postModules).map(([path, module]: [string, any]) => {
		const slug = path.split('/').pop()?.replace(/\.(md|mdx)$/, '');
		return {
			...module,
			slug,
			url: `/blog/${slug}/`
		};
	});
	const uniqueTags = [...new Set(allPosts.map((post) => post.frontmatter.tags).flat())];

	return uniqueTags.map((tag) => {
		const filteredPosts = allPosts.filter((post) => post.frontmatter.tags.includes(tag));
		return {
			params: { tag },
			props: { posts: filteredPosts },
		};
	});
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<script is:inline>
			if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
				document.documentElement.classList.add('dark')
			} else {
				document.documentElement.classList.remove('dark')
			}
		</script>
		<BaseHead title={`Tag: ${tag} - ${SITE_TITLE}`} description={`Posts tagged with ${tag}`} />
		<style>
			main {
				max-width: 800px;
				margin: 0 auto;
				padding: 2rem 1rem;
			}

			.tag-header {
				margin-bottom: 3rem;
			}

			.back-link {
				font-size: 0.875rem;
				color: #6b7280;
				text-decoration: none;
				display: inline-block;
				margin-bottom: 1rem;
			}

			.dark .back-link {
				color: #9ca3af;
			}

			.back-link:hover {
				text-decoration: underline;
			}

			.tag-title {
				font-size: 2.5rem;
				font-weight: bold;
				margin-bottom: 0.5rem;
				color: #000;
			}

			.dark .tag-title {
				color: #fff;
			}

			.tag-subtitle {
				color: #6b7280;
				font-size: 1rem;
			}

			.dark .tag-subtitle {
				color: #9ca3af;
			}

			.posts-list {
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
			}

			.post-item {
				border-radius: 16px;
				border: 1px solid #d1d5db;
				overflow: hidden;
				transition: all 0.3s ease;
				background-color: #e6e4e0;
			}

			.dark .post-item {
				border-color: #4b5563;
				background-color: #000000;
			}

			.post-item:hover {
				background-color: #c9c7c3;
			}

			.dark .post-item:hover {
				background-color: #2a2a2a;
			}

			.post-link {
				display: block;
				padding: 1.5rem;
				text-decoration: none;
				color: inherit;
			}

			.post-title {
				font-size: 1.5rem;
				font-weight: 600;
				color: #111827;
				margin-bottom: 0.5rem;
			}

			.dark .post-title {
				color: #f9fafb;
			}

			.post-description {
				color: #6b7280;
				line-height: 1.6;
			}

			.dark .post-description {
				color: #9ca3af;
			}

			@media (max-width: 768px) {
				main {
					padding: 1rem;
				}

				.tag-title {
					font-size: 2rem;
				}

				.post-title {
					font-size: 1.25rem;
				}
			}

		</style>
	</head>
	<body>
		<SkipLink />
		<Header />
		<Breadcrumbs items={[
			{ label: 'Home', href: '/' },
			{ label: 'Tags', href: '/tags' },
			{ label: tag }
		]} />
		<main id="main-content">
			<div class="tag-header">
				<a href="/tags" class="back-link">← Tous les tags</a>
				<h1 class="tag-title">Tag: {tag}</h1>
				<p class="tag-subtitle">{posts.length} article{posts.length > 1 ? 's' : ''}</p>
			</div>
			<ul class="posts-list">
				{posts.map((post) => (
					<li class="post-item">
						<a href={post.url} class="post-link">
							<h2 class="post-title">{post.frontmatter.title}</h2>
							<p class="post-description">{post.frontmatter.description}</p>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
