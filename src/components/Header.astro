---
import { SITE_TITLE } from '../consts';
import SearchModal from './SearchModal.astro';

const currentPath = Astro.url.pathname;
const isActive = (path: string) => {
  if (path === '/blog') {
    return currentPath.startsWith('/blog');
  }
  if (path === '/tags') {
    return currentPath.startsWith('/tags');
  }
  if (path === '/about') {
    return currentPath === '/about' || currentPath === '/about/';
  }
  return false;
};
---

<!-- Top Navigation Bar -->
<header class="header-nav" data-pagefind-ignore>
  <nav class="header-container">
    <!-- Logo/Title -->
    <a href="/" class="logo" aria-label="Home">
      <span class="logo-text">{SITE_TITLE}</span>
    </a>

    <!-- Desktop Navigation Links -->
    <div class="nav-links">
      <a href="/blog" class:list={['nav-link', { 'active': isActive('/blog') }]}>Blog</a>
      <a href="/tags" class:list={['nav-link', { 'active': isActive('/tags') }]}>Tags</a>
      <a href="/about" class:list={['nav-link', { 'active': isActive('/about') }]}>About</a>
    </div>

    <!-- Right Side: Search & Theme Toggle -->
    <div class="nav-actions">
      <!-- Search Button -->
      <button class="search-button" id="search-button" aria-label="Search">
        <svg class="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <span class="search-shortcut">⌘K</span>
      </button>

      <!-- Theme Toggle -->
      <button class="theme-toggle"
              onclick="window.toggleTheme()"
              aria-label="Toggle dark mode">
        <svg class="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
          <path fill="currentColor" d="M12 7a5 5 0 100 10V7z"/>
        </svg>
      </button>
    </div>
  </nav>
</header>

<!-- Search Modal -->
<SearchModal />

<style>
  /* Header fixed at top with glassmorphism */
  .header-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: var(--color-glass);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .header-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  /* Logo */
  .logo {
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .logo-text {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    transition: color 200ms ease;
  }

  .logo:hover .logo-text {
    color: var(--color-accent);
  }

  /* Navigation Links */
  .nav-links {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .nav-link {
    color: var(--color-text);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9375rem;
    transition: color 200ms ease;
    position: relative;
  }

  .nav-link:hover {
    color: var(--color-accent);
  }

  /* Active link underline */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transition: transform 200ms ease;
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    transform: scaleX(1);
  }

  .nav-link.active {
    color: var(--color-accent);
  }

  /* Actions (search & theme toggle) */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .search-button,
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    height: 36px;
    border-radius: 9999px;
    color: var(--color-text);
    background: transparent;
    border: none;
    cursor: pointer;
    transition: background 200ms ease, color 200ms ease, transform 200ms ease;
  }

  .search-button {
    padding: 0 0.75rem;
  }

  .theme-toggle {
    width: 36px;
  }

  .search-button:hover,
  .theme-toggle:hover {
    background: var(--color-surface);
    color: var(--color-accent);
    transform: translateY(-2px);
  }

  .search-shortcut {
    font-size: 0.75rem;
    color: var(--color-muted);
    font-weight: 500;
    padding: 0.125rem 0.375rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
  }

  .icon {
    width: 20px;
    height: 20px;
  }

  /* Add padding to body to account for fixed header */
  :global(body) {
    padding-top: 4rem;
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .header-container {
      padding: 0.75rem 1rem;
    }

    .nav-links {
      gap: 1rem;
    }

    .nav-link {
      font-size: 0.875rem;
    }

    .logo-text {
      font-size: 1.125rem;
    }

    .search-button,
    .theme-toggle {
      width: 32px;
      height: 32px;
      padding: 0;
    }

    .search-shortcut {
      display: none;
    }

    .icon {
      width: 18px;
      height: 18px;
    }
  }
</style>
