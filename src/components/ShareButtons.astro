---
export interface Props {
  title: string;
  description: string;
  url: string;
}

const { title, description, url } = Astro.props;
const fullUrl = `https://reho.dev${url}`;
---

<div class="share-buttons">
  <button class="share-btn share-native" data-title={title} data-text={description} data-url={fullUrl}>
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
    </svg>
    <span>Share</span>
  </button>

  <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(fullUrl)}`}
     target="_blank"
     rel="noopener noreferrer"
     class="share-btn share-twitter"
     aria-label="Share on X (Twitter)">
    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
    </svg>
  </a>

  <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(fullUrl)}`}
     target="_blank"
     rel="noopener noreferrer"
     class="share-btn share-linkedin"
     aria-label="Share on LinkedIn">
    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
    </svg>
  </a>

  <button class="share-btn share-copy" data-url={fullUrl} aria-label="Copy link">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/>
    </svg>
    <span class="copy-text">Copy</span>
  </button>
</div>

<script>
  function initShareButtons() {
    // Web Share API for native share
    document.querySelectorAll('.share-native').forEach(button => {
      if (!navigator.share) {
        button.style.display = 'none';
        return;
      }

      button.addEventListener('click', async () => {
        const btn = button as HTMLElement;
        try {
          await navigator.share({
            title: btn.dataset.title,
            text: btn.dataset.text,
            url: btn.dataset.url,
          });
        } catch (err) {
          // User cancelled or error - silent fail
          if ((err as Error).name !== 'AbortError') {
            console.log('Share failed:', err);
          }
        }
      });
    });

    // Copy to clipboard
    document.querySelectorAll('.share-copy').forEach(button => {
      button.addEventListener('click', async () => {
        const btn = button as HTMLElement;
        const url = btn.dataset.url || '';
        const textSpan = btn.querySelector('.copy-text');

        try {
          await navigator.clipboard.writeText(url);
          if (textSpan) {
            textSpan.textContent = 'Copied!';
            setTimeout(() => {
              textSpan.textContent = 'Copy';
            }, 2000);
          }
        } catch (err) {
          console.error('Failed to copy:', err);
        }
      });
    });
  }

  // Init on load
  document.addEventListener('DOMContentLoaded', initShareButtons);

  // Re-init on Astro view transitions
  document.addEventListener('astro:page-load', initShareButtons);
</script>

<style>
  .share-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    margin: 2rem 0;
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    border-radius: 9999px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 200ms ease, transform 200ms ease, color 200ms ease;
  }

  .share-btn:hover {
    background: var(--color-accent);
    color: white;
    transform: translateY(-2px);
  }

  .share-btn:active {
    transform: translateY(0);
  }

  .share-btn svg {
    flex-shrink: 0;
  }

  .share-native {
    background: var(--gradient-accent);
    color: white;
    border-color: transparent;
  }

  .share-native:hover {
    background: var(--color-accent-hover);
  }

  .share-twitter:hover {
    background: #1DA1F2;
    border-color: #1DA1F2;
  }

  .share-linkedin:hover {
    background: #0A66C2;
    border-color: #0A66C2;
  }

  /* Hide native share button text on small screens */
  @media (max-width: 640px) {
    .share-native span {
      display: none;
    }
  }
</style>
