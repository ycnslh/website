---
import { Image } from 'astro:assets';
import { getCollection, type CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TOC from '../components/TOC.astro';
import ShareButtons from '../components/ShareButtons.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import Badge from '../components/ui/Badge.astro';
import SkipLink from '../components/SkipLink.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { getRelatedPosts } from '../utils/relatedPosts';

type Props = CollectionEntry<'blog'>['data'] & {
	readingTime?: string;
	headings?: MarkdownHeading[];
	entry?: CollectionEntry<'blog'>;
	tags?: string[];
};

const { title, description, pubDate, updatedDate, heroImage, readingTime, tags, headings = [], entry } = Astro.props;

// Get all posts for related posts
const allPosts = await getCollection('blog');
const relatedPosts = entry ? getRelatedPosts(entry, allPosts, 3) : [];

// Build URL for sharing
const currentUrl = Astro.url.pathname;
---

<html lang="en">
	<head>
		<script is:inline>
			if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
				document.documentElement.classList.add('dark')
			} else {
				document.documentElement.classList.remove('dark')
			}
		</script>
		<BaseHead title={title} description={description} />
		<style>
			.article-container {
				max-width: 1200px;
				margin: 0 auto;
				padding: 2rem 1rem;
			}

			.article-layout {
				display: grid;
				grid-template-columns: 1fr;
				gap: 3rem;
			}

			main {
				max-width: 800px;
				width: 100%;
			}

			.toc-wrapper {
				display: none;
			}

			@media (min-width: 1024px) {
				.article-layout {
					grid-template-columns: 1fr 300px;
				}

				.toc-wrapper {
					display: block;
				}

				.toc-wrapper.desktop {
					position: sticky;
					top: 2rem;
					align-self: start;
					max-height: calc(100vh - 4rem);
					overflow-y: auto;
				}

				.toc-wrapper.mobile {
					display: none;
				}
			}

			@media (max-width: 1023px) {
				.toc-wrapper.mobile {
					display: block;
					margin-bottom: 2rem;
				}
			}

			.hero-image {
				width: 100%;
				margin-bottom: 3rem;
			}

			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 16px;
				width: 100%;
				height: auto;
				border: 1px solid #d1d5db;
			}

			.dark .hero-image img {
				border-color: #4b5563;
			}

			.article-header {
				text-align: center;
				margin-bottom: 3rem;
				padding-bottom: 2rem;
				border-bottom: 1px solid #d1d5db;
			}

			.dark .article-header {
				border-bottom-color: #4b5563;
			}

			.article-title {
				font-size: 2.5rem;
				font-weight: bold;
				color: #000;
				margin-bottom: 1rem;
				line-height: 1.2;
			}

			.dark .article-title {
				color: #fff;
			}

			.article-meta {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 2rem;
				color: #6b7280;
				font-size: 0.875rem;
				margin-bottom: 1rem;
			}

			.dark .article-meta {
				color: #9ca3af;
			}

			.date-info, .reading-time {
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}

			.last-updated {
				font-style: italic;
				color: #9ca3af;
				font-size: 0.8rem;
			}

			.dark .last-updated {
				color: #6b7280;
			}

			.tags-container {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				justify-content: center;
				margin-top: 1rem;
			}


			/* Simple heading styles - direct targeting */
			h1 {
				font-size: 2.25rem !important;
				font-weight: 800 !important;
				margin-top: 2rem !important;
				margin-bottom: 1rem !important;
				color: #000 !important;
			}

			h2 {
				font-size: 1.875rem !important;
				font-weight: 700 !important;
				margin-top: 2rem !important;
				margin-bottom: 1rem !important;
				color: #000 !important;
			}

			h3 {
				font-size: 1.5rem !important;
				font-weight: 600 !important;
				margin-top: 1.5rem !important;
				margin-bottom: 0.75rem !important;
				color: #000 !important;
			}

			h4 {
				font-size: 1.25rem !important;
				font-weight: 600 !important;
				margin-top: 1.5rem !important;
				margin-bottom: 0.5rem !important;
				color: #000 !important;
			}

			h5 {
				font-size: 1.125rem !important;
				font-weight: 600 !important;
				margin-top: 1rem !important;
				margin-bottom: 0.5rem !important;
				color: #000 !important;
			}

			h6 {
				font-size: 1rem !important;
				font-weight: 600 !important;
				margin-top: 1rem !important;
				margin-bottom: 0.5rem !important;
				color: #000 !important;
			}

			.dark h1, .dark h2, .dark h3, .dark h4, .dark h5, .dark h6 {
				color: #fff !important;
			}


			@media (max-width: 768px) {
				main {
					padding: 1rem;
				}

				.article-title {
					font-size: 2rem;
				}

				.article-meta {
					flex-direction: column;
					gap: 0.5rem;
				}

				.prose {
					font-size: 1rem;
				}

				.prose h2 {
					font-size: 1.5rem;
				}

				.prose h3 {
					font-size: 1.2rem;
				}
			}
		</style>
	</head>

	<body>
		<ReadingProgress />
		<SkipLink />
		<Header />
		<Breadcrumbs items={[
			{ label: 'Home', href: '/' },
			{ label: 'Blog', href: '/blog' },
			{ label: title }
		]} />
		<div class="article-container">
			<div class="article-layout">
				<main id="main-content">
					<!-- TOC Mobile (en haut sur mobile) -->
					<div class="toc-wrapper mobile">
						<TOC headings={headings} />
					</div>

					<article>
						{heroImage && (
							<div class="hero-image">
								<Image width={1020} height={510} src={heroImage} alt={title} />
							</div>
						)}

						<div class="article-header">
							<h1 class="article-title">{title}</h1>
							<div class="article-meta">
								<div class="date-info">
									<svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
										<path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z"/>
									</svg>
									<FormattedDate date={pubDate} />
								</div>
								{readingTime && (
									<div class="reading-time">
										<svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
											<path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/>
										</svg>
										{readingTime}
									</div>
								)}
								{updatedDate && (
									<div class="last-updated">
										Updated <FormattedDate date={updatedDate} />
									</div>
								)}
							</div>
							{tags && tags.length > 0 && (
								<div class="tags-container">
									{tags.map((tag) => (
										<Badge variant="muted" href={`/tags/${tag}/`}>
											{tag}
										</Badge>
									))}
								</div>
							)}
						</div>

						<div class="prose prose-lg max-w-none dark:prose-invert">
							<slot />
						</div>

						<!-- Share Buttons -->
						<div>
							<ShareButtons title={title} description={description} url={currentUrl} />
						</div>

						<!-- Related Posts -->
						{relatedPosts.length > 0 && (
							<div>
								<RelatedPosts posts={relatedPosts} />
							</div>
						)}
					</article>
				</main>

				<!-- TOC Desktop (à droite sur desktop, sticky) -->
				<aside class="toc-wrapper desktop">
					<TOC headings={headings} />
				</aside>
			</div>
		</div>
		<Footer />
	</body>
</html>
